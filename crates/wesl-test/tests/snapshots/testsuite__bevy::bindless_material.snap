@group(2) @binding(0)
var<uniform> material_color: Color;

@group(2) @binding(2)
var material_color_sampler: sampler;

@group(2) @binding(1)
var material_color_texture: texture_2d<f32>;

struct Color {
    base_color: vec4<f32>
}

struct bevy_pbr__1forward_io_VertexOutput {
    @builtin(position)
    position: vec4<f32>,
    @location(0)
