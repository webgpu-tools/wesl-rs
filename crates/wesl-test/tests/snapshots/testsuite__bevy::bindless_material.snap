}

@fragment
fn fragment(in: bevy_pbr__1forward_io_VertexOutput) -> @location(0) vec4<f32> {
    let base_color: vec4<f32> = material_color.base_color;
    return base_color * textureSampleLevel(material_color_texture, material_color_sampler, in.uv, 0.0);
