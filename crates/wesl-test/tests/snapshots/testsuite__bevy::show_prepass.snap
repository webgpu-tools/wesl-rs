@group(0) @binding(28)
var bevy_pbr__2mesh_view_bindings__2depth_prepass_texture: texture_depth_multisampled_2d;

@group(0) @binding(29)
var bevy_pbr__2mesh_view_bindings__2normal_prepass_texture: texture_multisampled_2d<f32>;

@group(0) @binding(30)
var bevy_pbr__2mesh_view_bindings__3motion_vector_prepass_texture: texture_multisampled_2d<f32>;

@group(0) @binding(11)
var<uniform> bevy_pbr__2mesh_view_bindings_globals: bevy_render_globals_Globals;

@group(2) @binding(0)
var<uniform> settings: ShowPrepassSettings;

struct ShowPrepassSettings {
    show_depth: u32,
    show_normals: u32,
    show_motion_vectors: u32,
    padding_1: u32,
    padding_2: u32
}

struct bevy_pbr__1forward_io_VertexOutput {
    @builtin(position)
