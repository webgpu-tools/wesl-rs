}

fn bevy_pbr__1prepass_utils__1prepass_depth(frag_coord: vec4<f32>, sample_index: u32) -> f32 {
    return textureLoad(bevy_pbr__2mesh_view_bindings__2depth_prepass_texture, vec2<i32>(frag_coord.xy), i32(sample_index));
}

fn bevy_pbr__1prepass_utils__1prepass_normal(frag_coord: vec4<f32>, sample_index: u32) -> vec3<f32> {
    let normal_sample: vec4<f32> = textureLoad(bevy_pbr__2mesh_view_bindings__2normal_prepass_texture, vec2<i32>(frag_coord.xy), i32(sample_index));
    return normalize(normal_sample.xyz * 2.0 - vec3(1.0, 1.0, 1.0));
}

fn bevy_pbr__1prepass_utils__2prepass_motion_vector(frag_coord: vec4<f32>, sample_index: u32) -> vec2<f32> {
    let motion_vector_sample: vec4<f32> = textureLoad(bevy_pbr__2mesh_view_bindings__3motion_vector_prepass_texture, vec2<i32>(frag_coord.xy), i32(sample_index));
    return motion_vector_sample.rg;
}

@fragment
fn fragment(@builtin(sample_index) sample_index: u32, mesh: bevy_pbr__1forward_io_VertexOutput) -> @location(0) vec4<f32> {
    if settings.show_depth == 1u {
        let depth: f32 = bevy_pbr__1prepass_utils__1prepass_depth(mesh.position, sample_index);
        return vec4(depth, depth, depth, 1.0);
    }
    else if settings.show_normals == 1u {
        let normal: vec3<f32> = bevy_pbr__1prepass_utils__1prepass_normal(mesh.position, sample_index);
        return vec4(normal, 1.0);
    }
    else if settings.show_motion_vectors == 1u {
        let motion_vector: vec2<f32> = bevy_pbr__1prepass_utils__2prepass_motion_vector(mesh.position, sample_index);
        return vec4(motion_vector / bevy_pbr__2mesh_view_bindings_globals.delta_time, 0.0, 1.0);
    }
    return vec4(0f, 0f, 0f, 0f);
}
