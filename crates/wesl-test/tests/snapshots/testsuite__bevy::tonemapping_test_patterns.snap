struct bevy_pbr__1forward_io_VertexOutput {
    @builtin(position)
    position: vec4<f32>,
    @location(0)
    world_position: vec4<f32>,
    @location(1)
    world_normal: vec3<f32>,
    @location(2)
    uv: vec2<f32>,
    @location(6) @interpolate(flat)
    instance_index: u32
}

fn color_sweep(uv_input: vec2<f32>) -> vec3<f32> {
    var uv: vec2<f32> = uv_input;
    let steps: f32 = 24.0;
    uv.y = uv.y * (1.0 + 1.0 / steps);
    let ratio: f32 = 2.0;
    let h: f32 = 6.2831855f * floor(1.0 + steps * uv.y) / steps;
    let L: f32 = floor(uv.x * steps * ratio) / (steps * ratio) - 0.5;
    var color: vec3<f32> = vec3(0.0, 0.0, 0.0);
    if uv.y < 1.0 {
        color = cos(h + vec3(0f, 2.0943952f, 4.1887903f));
        let maxRGB: f32 = max(color.r, max(color.g, color.b));
        let minRGB: f32 = min(color.r, min(color.g, color.b));
        color = exp(15.0 * L) * (color - minRGB) / (maxRGB - minRGB);
    }
    else {
        color = vec3(exp(15.0 * L));
    }
    return color;
}

fn continuous_hue(uv: vec2<f32>) -> vec3<f32> {
    return hsv_to_srgb(vec3(uv.x, 1.0, 1.0)) * max(0.0, exp2(uv.y * 9.0) - 1.0);
}

@fragment
fn fragment(in: bevy_pbr__1forward_io_VertexOutput) -> @location(0) vec4<f32> {
    var uv: vec2<f32> = in.uv;
    var out: vec3<f32> = vec3(0.0, 0.0, 0.0);
    if uv.y > 0.5 {
        uv.y = 1.0 - uv.y;
        out = color_sweep(vec2(uv.x, uv.y * 2.0));
    }
    else {
        out = continuous_hue(vec2(uv.y * 2.0, uv.x));
    }
    var color: vec4<f32> = vec4(out, 1.0);
    return color;
}

fn hsv_to_srgb(c: vec3<f32>) -> vec3<f32> {
    let K: vec4<f32> = vec4(1.0, 0.6666666666666666, 0.3333333333333333, 3.0);
    let p: vec3<f32> = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
    return c.z * mix(K.xxx, clamp(p - K.xxx, vec3(0.0, 0.0, 0.0), vec3(1.0, 1.0, 1.0)), c.y);
}
