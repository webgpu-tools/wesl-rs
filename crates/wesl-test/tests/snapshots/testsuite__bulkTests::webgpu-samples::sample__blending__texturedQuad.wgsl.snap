---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
@group(0) @binding(0)
var ourSampler: sampler;

@group(0) @binding(1)
var ourTexture: texture_2d<f32>;

@group(0) @binding(2)
var<uniform> uni: Uniforms;

struct OurVertexShaderOutput {
    @builtin(position)
    position: vec4<f32>,
    @location(0)
    texcoord: vec2<f32>
}

struct Uniforms {
    matrix: mat4x4<f32>
}

@fragment
fn fs(fsInput: OurVertexShaderOutput) -> @location(0) vec4<f32> {
    return textureSample(ourTexture, ourSampler, fsInput.texcoord);
}

@vertex
fn vs(@builtin(vertex_index) vertexIndex: u32) -> OurVertexShaderOutput {
    let pos: array<vec2<f32>, 6> = array(vec2(0f, 0f), vec2(1f, 0f), vec2(0f, 1f), vec2(0f, 1f), vec2(1f, 0f), vec2(1f, 1f));
    var vsOutput: OurVertexShaderOutput;
    let xy: vec2<f32> = pos[vertexIndex];
    vsOutput.position = uni.matrix * vec4<f32>(xy, 0.0, 1.0);
    vsOutput.texcoord = xy;
    return vsOutput;
}
