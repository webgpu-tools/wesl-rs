source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
@group(0) @binding(1)
var mySampler: sampler;

@group(0) @binding(2)
var myTexture: texture_2d<f32>;

@group(0) @binding(0)
var<uniform> uniforms: Uniforms;

struct Uniforms {
    modelViewProjectionMatrix: mat4x4<f32>
}

struct VertexOutput {
    @builtin(position)
    Position: vec4<f32>,
    @location(0)
    fragUV: vec2<f32>
}

@fragment
fn fragment_main(@location(0) fragUV: vec2<f32>) -> @location(0) vec4<f32> {
    return textureSample(myTexture, mySampler, fragUV);
}

@vertex
fn vertex_main(@location(0) position: vec4<f32>, @location(1) uv: vec2<f32>) -> VertexOutput {
    return VertexOutput(uniforms.modelViewProjectionMatrix * position, uv);
}
