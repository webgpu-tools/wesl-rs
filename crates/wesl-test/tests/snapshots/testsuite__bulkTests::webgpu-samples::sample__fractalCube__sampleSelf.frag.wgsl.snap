expression: res.syntax.to_string()
---
@binding(1) @group(0)
var mySampler: sampler;

@binding(2) @group(0)
var myTexture: texture_2d<f32>;

@fragment
fn main(@location(0) fragUV: vec2<f32>, @location(1) fragPosition: vec4<f32>) -> @location(0) vec4<f32> {
    let texColor: vec4<f32> = textureSample(myTexture, mySampler, fragUV * 0.8 + vec2(0.1, 0.1));
    let f: f32 = select(1.0, 0.0, length(texColor.rgb - vec3(0.5, 0.5, 0.5)) < 0.01);
    return f * texColor + (1.0 - f) * fragPosition;
}
