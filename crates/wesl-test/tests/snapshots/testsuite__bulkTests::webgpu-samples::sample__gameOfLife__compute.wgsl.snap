---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
override blockSize: i32 = 8;

@binding(1) @group(0)
var<storage, read> current: array<u32>;

@binding(2) @group(0)
var<storage, read_write> next: array<u32>;

@binding(0) @group(0)
var<storage, read> size: vec2<u32>;

fn countNeighbors(x: u32, y: u32) -> u32 {
    return getCell(x - 1, y - 1) + getCell(x, y - 1) + getCell(x + 1, y - 1) + getCell(x - 1, y) + getCell(x + 1, y) + getCell(x - 1, y + 1) + getCell(x, y + 1) + getCell(x + 1, y + 1);
}

fn getCell(x: u32, y: u32) -> u32 {
    return current[getIndex(x, y)];
}

fn getIndex(x: u32, y: u32) -> u32 {
    let h: u32 = size.y;
    let w: u32 = size.x;
    return (y % h) * w + (x % w);
}

@compute @workgroup_size(blockSize, blockSize)
fn main(@builtin(global_invocation_id) grid: vec3<u32>) {
    let x: u32 = grid.x;
    let y: u32 = grid.y;
    let n: u32 = countNeighbors(x, y);
    next[getIndex(x, y)] = select(u32(n == 3u), u32(n == 2u || n == 3u), getCell(x, y) == 1u);
}
