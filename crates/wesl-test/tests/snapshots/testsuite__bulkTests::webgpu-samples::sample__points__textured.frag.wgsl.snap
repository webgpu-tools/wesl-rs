---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
@group(0) @binding(1)
var s: sampler;

@group(0) @binding(2)
var t: texture_2d<f32>;

struct VSOutput {
    @location(0)
    texcoord: vec2<f32>
}

@fragment
fn fs(vsOut: VSOutput) -> @location(0) vec4<f32> {
    let color: vec4<f32> = textureSample(t, s, vsOut.texcoord);
    if (color.a < 0.1) {
        discard;
    }
    return color;
}
