@binding(1) @group(0)
var<uniform> camera: Camera;

@binding(0) @group(0)
var<uniform> uniforms: Uniforms;

struct Camera {
    viewProjectionMatrix: mat4x4<f32>
}

struct Uniforms {
    modelMatrix: array<mat4x4<f32>, 5>
}

@vertex
fn main(@builtin(instance_index) instanceIdx: u32, @location(0) position: vec4<f32>) -> @builtin(position) vec4<f32> {
    return camera.viewProjectionMatrix * uniforms.modelMatrix[instanceIdx] * position;
}
