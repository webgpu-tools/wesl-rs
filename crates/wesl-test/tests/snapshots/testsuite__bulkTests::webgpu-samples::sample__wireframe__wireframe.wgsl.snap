---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
@group(0) @binding(2)
var<storage, read> indices: array<u32>;

@group(0) @binding(3)
var<uniform> line: LineUniforms;

@group(0) @binding(1)
var<storage, read> positions: array<f32>;

@group(0) @binding(0)
var<uniform> uni: Uniforms;

struct BarycentricCoordinateBasedVSOutput {
    @builtin(position)
    position: vec4<f32>,
    @location(0)
    barycenticCoord: vec3<f32>
}

struct LineUniforms {
    stride: u32,
    thickness: f32,
    alphaThreshold: f32
}

struct Uniforms {
    worldViewProjectionMatrix: mat4x4<f32>,
    worldMatrix: mat4x4<f32>,
    color: vec4<f32>
}

struct VSOut {
    @builtin(position)
    position: vec4<f32>
}

fn edgeFactor(bary: vec3<f32>) -> f32 {
    let d: vec3<f32> = fwidth(bary);
    let a3: vec3<f32> = smoothstep(vec3(0f, 0f, 0f), d * line.thickness, bary);
    return min(min(a3.x, a3.y), a3.z);
}

@fragment
fn fs() -> @location(0) vec4<f32> {
    return uni.color + vec4(0.5f, 0.5f, 0.5f, 0.5f);
}

@fragment
fn fsBarycentricCoordinateBasedLines(v: BarycentricCoordinateBasedVSOutput) -> @location(0) vec4<f32> {
    let a: f32 = 1.0 - edgeFactor(v.barycenticCoord);
    if (a < line.alphaThreshold) {
        discard;
    }
    return vec4((uni.color.rgb + 0.5) * a, a);
}

@vertex
fn vsIndexedU32(@builtin(vertex_index) vNdx: u32) -> VSOut {
    let triNdx: u32 = vNdx / 6;
    let vertNdx: u32 = (vNdx % 2 + vNdx / 2) % 3;
    let index: u32 = indices[triNdx * 3 + vertNdx];
    let pNdx: u32 = index * line.stride;
    let position: vec4<f32> = vec4<f32>(positions[pNdx], positions[pNdx + 1], positions[pNdx + 2], 1);
    var vOut: VSOut;
    vOut.position = uni.worldViewProjectionMatrix * position;
    return vOut;
}

@vertex
fn vsIndexedU32BarycentricCoordinateBasedLines(@builtin(vertex_index) vNdx: u32) -> BarycentricCoordinateBasedVSOutput {
    let vertNdx: u32 = vNdx % 3;
    let index: u32 = indices[vNdx];
    let pNdx: u32 = index * line.stride;
    let position: vec4<f32> = vec4<f32>(positions[pNdx], positions[pNdx + 1], positions[pNdx + 2], 1);
    var vsOut: BarycentricCoordinateBasedVSOutput;
    vsOut.position = uni.worldViewProjectionMatrix * position;
    vsOut.barycenticCoord = vec3(0f, 0f, 0f);
    vsOut.barycenticCoord[vertNdx] = 1.0;
    return vsOut;
}
