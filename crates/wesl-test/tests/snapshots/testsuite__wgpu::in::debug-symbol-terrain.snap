---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
@group(0) @binding(0)
var<uniform> camera: Camera;

@group(0) @binding(0)
var<uniform> chunk_data: ChunkData;

@group(0) @binding(0)
var<uniform> gen_data: GenData;

@group(0) @binding(2)
var<storage, read_write> indices: IndexBuffer;

@group(1) @binding(0)
var<uniform> light: Light;

@group(0) @binding(1)
var<storage, read_write> vertices: VertexBuffer;

struct Camera {
    view_pos: vec4<f32>,
    view_proj: mat4x4<f32>
}

struct ChunkData {
    chunk_size: vec2<u32>,
    chunk_corner: vec2<i32>,
    min_max_height: vec2<f32>
}

struct GenData {
    chunk_size: vec2<u32>,
    chunk_corner: vec2<i32>,
    min_max_height: vec2<f32>,
    texture_size: u32,
    start_index: u32
}

struct GenFragmentOutput {
    @location(0)
    vert_component: u32,
    @location(1)
    index: u32
}

struct GenVertexOutput {
    @location(0)
    index: u32,
    @builtin(position)
    position: vec4<f32>,
    @location(1)
    uv: vec2<f32>
}

struct IndexBuffer {
    data: array<u32>
}

struct Light {
    position: vec3<f32>,
    color: vec3<f32>
}

struct Vertex {
    @location(0)
    position: vec3<f32>,
    @location(1)
    normal: vec3<f32>
}

struct VertexBuffer {
    data: array<Vertex>
}

struct VertexOutput {
    @builtin(position)
    clip_position: vec4<f32>,
    @location(0)
    normal: vec3<f32>,
    @location(1)
    world_pos: vec3<f32>
}

fn fbm(p: vec2<f32>) -> f32 {
    let NUM_OCTAVES: u32 = 5u;
    var x: vec2<f32> = p * 0.01;
    var v: f32 = 0.0;
    var a: f32 = 0.5;
    let shift: vec2<f32> = vec2(100f, 100f);
    let cs: vec2<f32> = vec2(0.87758255f, 0.47942555f);
    let rot: mat2x2<f32> = mat2x2<f32>(cs.x, cs.y, -cs.y, cs.x);
    for (var i: u32 = 0u; i < NUM_OCTAVES; i = i + 1u) {
        v = v + a * snoise2(x);
        x = rot * x * 2.0 + shift;
        a = a * 0.5;
    }
    return v;
}

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    var color: vec3<f32> = smoothstep(vec3(0f, 0f, 0f), vec3(0.1f, 0.1f, 0.1f), fract(in.world_pos));
    color = mix(vec3(0.5f, 0.1f, 0.7f), vec3(0.2f, 0.2f, 0.2f), vec3<f32>(color.x * color.y * color.z));
    let ambient_strength: f32 = 0.1;
    let ambient_color: vec3<f32> = light.color * ambient_strength;
    let light_dir: vec3<f32> = normalize(light.position - in.world_pos);
    let view_dir: vec3<f32> = normalize(camera.view_pos.xyz - in.world_pos);
    let half_dir: vec3<f32> = normalize(view_dir + light_dir);
    let diffuse_strength: f32 = max(dot(in.normal, light_dir), 0.0);
    let diffuse_color: vec3<f32> = diffuse_strength * light.color;
    let specular_strength: f32 = pow(max(dot(in.normal, half_dir), 0.0), 32.0);
    let specular_color: vec3<f32> = specular_strength * light.color;
    let result: vec3<f32> = (ambient_color + diffuse_color + specular_color) * color;
    return vec4<f32>(result, 1.0);
}

@compute @workgroup_size(64)
fn gen_terrain_compute(@builtin(global_invocation_id) gid: vec3<u32>) {
    let vert_index: u32 = gid.x;
    let p: vec2<f32> = index_to_p(vert_index, chunk_data.chunk_size, chunk_data.chunk_corner);
    vertices.data[vert_index] = terrain_vertex(p, chunk_data.min_max_height);
    let start_index: u32 = gid.x * 6u;
    if (start_index >= (chunk_data.chunk_size.x * chunk_data.chunk_size.y * 6u)) {
        return;
    }
    let v00: u32 = vert_index + gid.x / chunk_data.chunk_size.x;
    let v10: u32 = v00 + 1u;
    let v01: u32 = v00 + chunk_data.chunk_size.x + 1u;
    let v11: u32 = v01 + 1u;
    indices.data[start_index] = v00;
    indices.data[start_index + 1u] = v01;
    indices.data[start_index + 2u] = v11;
    indices.data[start_index + 3u] = v00;
    indices.data[start_index + 4u] = v11;
    indices.data[start_index + 5u] = v10;
}

@fragment
fn gen_terrain_fragment(in: GenVertexOutput) -> GenFragmentOutput {
    let i: u32 = u32(in.uv.x * f32(gen_data.texture_size) + in.uv.y * f32(gen_data.texture_size * gen_data.texture_size)) + gen_data.start_index;
    let vert_index: u32 = u32(floor(f32(i) / 6.0));
    let comp_index: u32 = i % 6u;
    let p: vec2<f32> = index_to_p(vert_index, gen_data.chunk_size, gen_data.chunk_corner);
    let v: Vertex = terrain_vertex(p, gen_data.min_max_height);
    var vert_component: f32 = 0.0;
    switch comp_index {
        case 0u {
            vert_component = v.position.x;
        }
        case 1u {
            vert_component = v.position.y;
        }
        case 2u {
            vert_component = v.position.z;
        }
        case 3u {
            vert_component = v.normal.x;
        }
        case 4u {
            vert_component = v.normal.y;
        }
        case 5u {
            vert_component = v.normal.z;
        }
        case default {
        
        }
    }
    let v00: u32 = vert_index + vert_index / gen_data.chunk_size.x;
    let v10: u32 = v00 + 1u;
    let v01: u32 = v00 + gen_data.chunk_size.x + 1u;
    let v11: u32 = v01 + 1u;
    var index: u32 = 0u;
    switch comp_index {
        case 0u, 3u {
            index = v00;
        }
        case 2u, 4u {
            index = v11;
        }
        case 1u {
            index = v01;
        }
        case 5u {
            index = v10;
        }
        case default {
        
        }
    }
    index = in.index;
    let ivert_component: u32 = bitcast<u32>(vert_component);
    return GenFragmentOutput(ivert_component, index);
}

@vertex
fn gen_terrain_vertex(@builtin(vertex_index) vindex: u32) -> GenVertexOutput {
    let u: f32 = f32(((vindex + 2u) / 3u) % 2u);
    let v: f32 = f32(((vindex + 1u) / 3u) % 2u);
    let uv: vec2<f32> = vec2<f32>(u, v);
    let position: vec4<f32> = vec4<f32>(-1.0 + uv * 2.0, 0.0, 1.0);
    let index: u32 = u32(uv.x * f32(gen_data.texture_size) + uv.y * f32(gen_data.texture_size)) + gen_data.start_index;
    return GenVertexOutput(index, position, uv);
}

fn index_to_p(vert_index: u32, chunk_size: vec2<u32>, chunk_corner: vec2<i32>) -> vec2<f32> {
    return vec2(f32(vert_index) % f32(chunk_size.x + 1u), f32(vert_index / (chunk_size.x + 1u))) + vec2<f32>(chunk_corner);
}

fn permute3(x: vec3<f32>) -> vec3<f32> {
    return (((x * 34.0) + 1.0) * x) % vec3(289f, 289f, 289f);
}

fn snoise2(v: vec2<f32>) -> f32 {
    let C: vec4<f32> = vec4(0.21132487f, 0.36602542f, -0.57735026f, 0.024390243f);
    var i: vec2<f32> = floor(v + dot(v, C.yy));
    let x0: vec2<f32> = v - i + dot(i, C.xx);
    var i1: vec2<f32> = select(vec2(1f, 0f), vec2(0f, 1f), (x0.x < x0.y));
    var x12: vec4<f32> = x0.xyxy + C.xxzz - vec4<f32>(i1, 0.0, 0.0);
    i = i % vec2(289f, 289f);
    let p: vec3<f32> = permute3(permute3(i.y + vec3<f32>(0.0, i1.y, 1.0)) + i.x + vec3<f32>(0.0, i1.x, 1.0));
    var m: vec3<f32> = max(0.5 - vec3<f32>(dot(x0, x0), dot(x12.xy, x12.xy), dot(x12.zw, x12.zw)), vec3(0f, 0f, 0f));
    m = m * m;
    m = m * m;
    let x: vec3<f32> = 2.0 * fract(p * C.www) - 1.0;
    let h: vec3<f32> = abs(x) - 0.5;
    let ox: vec3<f32> = floor(x + 0.5);
    let a0: vec3<f32> = x - ox;
    m = m * (1.79284291400159 - 0.85373472095314 * (a0 * a0 + h * h));
    let g: vec3<f32> = vec3<f32>(a0.x * x0.x + h.x * x0.y, a0.yz * x12.xz + h.yz * x12.yw);
    return 130.0 * dot(m, g);
}

fn terrain_point(p: vec2<f32>, min_max_height: vec2<f32>) -> vec3<f32> {
    return vec3<f32>(p.x, mix(min_max_height.x, min_max_height.y, fbm(p)), p.y);
}

fn terrain_vertex(p: vec2<f32>, min_max_height: vec2<f32>) -> Vertex {
    let v: vec3<f32> = terrain_point(p, min_max_height);
    let tpx: vec3<f32> = terrain_point(p + vec2(0.1f, 0f), min_max_height) - v;
    let tpz: vec3<f32> = terrain_point(p + vec2(0f, 0.1f), min_max_height) - v;
    let tnx: vec3<f32> = terrain_point(p + vec2(-0.1f, 0f), min_max_height) - v;
    let tnz: vec3<f32> = terrain_point(p + vec2(0f, -0.1f), min_max_height) - v;
    let pn: vec3<f32> = normalize(cross(tpz, tpx));
    let nn: vec3<f32> = normalize(cross(tnz, tnx));
    let n: vec3<f32> = (pn + nn) * 0.5;
    return Vertex(v, n);
}

@vertex
fn vs_main(vertex: Vertex) -> VertexOutput {
    let clip_position: vec4<f32> = camera.view_proj * vec4<f32>(vertex.position, 1.0);
    let normal: vec3<f32> = vertex.normal;
    return VertexOutput(clip_position, normal, vertex.position);
}
