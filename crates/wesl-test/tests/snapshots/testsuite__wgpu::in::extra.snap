---
source: crates/wesl-test/tests/testsuite.rs
expression: res.syntax.to_string()
---
var<immediate> im: Immediates;

struct FragmentIn {
    @location(0)
    color: vec4<f32>,
    @builtin(primitive_index)
    primitive_index: u32
}

struct Immediates {
    index: u32,
    double: vec2<f32>
}

@fragment
fn main(in: FragmentIn) -> @location(0) vec4<f32> {
    if in.primitive_index == im.index {
        return in.color;
    }
    else {
        return vec4<f32>(vec3(1f, 1f, 1f) - in.color.rgb, in.color.a);
    }
}
