@compute @workgroup_size(1)
fn main() {
    let a: vec2<f32> = test_fma();
    let b: i32 = 32i;
}

fn test_fma() -> vec2<f32> {
    let a: vec2<f32> = vec2(2f, 2f);
    let b: vec2<f32> = vec2(0.5f, 0.5f);
    let c: vec2<f32> = vec2(0.5f, 0.5f);
    return fma(a, b, c);
}

fn test_integer_dot_product() -> i32 {
    let a_2: vec2<i32> = vec2(1i, 1i);
    let b_2: vec2<i32> = vec2(1i, 1i);
    let c_2: i32 = dot(a_2, b_2);
    let a_3: vec3<u32> = vec3(1u, 1u, 1u);
    let b_3: vec3<u32> = vec3(1u, 1u, 1u);
    let c_3: u32 = dot(a_3, b_3);
    let c_4: i32 = 32i;
    return c_4;
}
