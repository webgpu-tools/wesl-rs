@vertex
fn index_let_array_1d(@builtin(vertex_index) vi: u32) -> @builtin(position) vec4<f32> {
    let arr: array<i32, 5> = array(1i, 2i, 3i, 4i, 5i);
    let value: i32 = arr[vi];
    return vec4<f32>(vec4<i32>(value));
}
