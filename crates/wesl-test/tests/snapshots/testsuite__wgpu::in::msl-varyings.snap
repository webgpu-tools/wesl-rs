struct NoteInstance {
    @location(1)
    position: vec2<f32>
}

struct Vertex {
    @location(0)
    position: vec2<f32>
}

struct VertexOutput {
    @builtin(position)
    position: vec4<f32>
}

@fragment
fn fs_main(in: VertexOutput, note: NoteInstance) -> @location(0) vec4<f32> {
    let position: vec3<f32> = vec3(1f, 1f, 1f);
    return in.position;
}

@vertex
fn vs_main(vertex: Vertex, note: NoteInstance) -> VertexOutput {
    var out: VertexOutput;
    return out;
}
