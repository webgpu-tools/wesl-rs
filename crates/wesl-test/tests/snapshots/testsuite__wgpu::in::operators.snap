fn bool_cast(x: vec3<f32>) -> vec3<f32> {
    let y: vec3<bool> = vec3<bool>(x);
    return vec3<f32>(y);
}

fn builtins() -> vec4<f32> {
    let condition: bool = true;
    let s1: i32 = select(0, 1, condition);
    let s2: vec4<f32> = select(vec4(0f, 0f, 0f, 0f), vec4(1f, 1f, 1f, 1f), condition);
    let s3: vec4<f32> = vec4(1f, 1f, 1f, 1f);
    let m1: vec4<f32> = vec4(0.5f, 0.5f, 0.5f, 0.5f);
    let m2: vec4<f32> = vec4(0.1f, 0.1f, 0.1f, 0.1f);
    let b1: f32 = 0.000000000000000000000000000000000000000000001f;
    let b2: vec4<f32> = vec4(0.000000000000000000000000000000000000000000001f, 0.000000000000000000000000000000000000000000001f, 0.000000000000000000000000000000000000000000001f, 0.000000000000000000000000000000000000000000001f);
    let v_i32_zero: vec4<i32> = vec4(0i, 0i, 0i, 0i);
    return vec4<f32>(vec4<i32>(s1) + v_i32_zero) + s2 + m1 + m2 + b1 + b2;
}

