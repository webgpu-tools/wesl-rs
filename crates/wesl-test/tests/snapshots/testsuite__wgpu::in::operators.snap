fn splat(m: f32, n: i32) -> vec4<f32> {
    let a: vec2<f32> = (2.0 + vec2<f32>(m) - 4.0) / 8.0;
    let b: vec4<i32> = vec4<i32>(n) % 2;
    return a.xyxy + vec4<f32>(b);
}
