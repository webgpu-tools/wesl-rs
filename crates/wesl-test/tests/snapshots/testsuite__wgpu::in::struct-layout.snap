@group(0) @binding(3)
var<storage, read_write> needs_padding_storage: NeedsPadding;

@group(0) @binding(2)
var<uniform> needs_padding_uniform: NeedsPadding;

@group(0) @binding(1)
var<storage, read_write> no_padding_storage: NoPadding;

@group(0) @binding(0)
var<uniform> no_padding_uniform: NoPadding;

struct NeedsPadding {
    @location(0)
    f3_forces_padding: f32,
    @location(1)
    v3_needs_padding: vec3<f32>,
    @location(2)
    f3: f32
}

struct NoPadding {
    @location(0)
    v3: vec3<f32>,
    @location(1)
    f3: f32
}

@compute @workgroup_size(16, 1, 1)
fn needs_padding_comp() {
    var x: NeedsPadding;
    x = needs_padding_uniform;
    x = needs_padding_storage;
}

@fragment
fn needs_padding_frag(input: NeedsPadding) -> @location(0) vec4<f32> {
    _ = input;
    return vec4(0f, 0f, 0f, 0f);
}

@vertex
fn needs_padding_vert(input: NeedsPadding) -> @builtin(position) vec4<f32> {
    _ = input;
    return vec4(0f, 0f, 0f, 0f);
}

@compute @workgroup_size(16, 1, 1)
fn no_padding_comp() {
    var x: NoPadding;
    x = no_padding_uniform;
    x = no_padding_storage;
}

@fragment
fn no_padding_frag(input: NoPadding) -> @location(0) vec4<f32> {
    _ = input;
    return vec4(0f, 0f, 0f, 0f);
}

@vertex
fn no_padding_vert(input: NoPadding) -> @builtin(position) vec4<f32> {
    _ = input;
    return vec4(0f, 0f, 0f, 0f);
}
