var<workgroup> arr_i32: array<i32, 128>;

@compute @workgroup_size(4)
fn test_workgroupUniformLoad(@builtin(workgroup_id) workgroup_id: vec3<u32>) {
    let x: ptr<workgroup, i32> = &arr_i32[workgroup_id.x];
    let val: i32 = workgroupUniformLoad(x);
    if val > 10 {
        workgroupBarrier();
    }
}
