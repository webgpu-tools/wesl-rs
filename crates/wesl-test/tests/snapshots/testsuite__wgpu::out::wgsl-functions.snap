@compute @workgroup_size(1, 1, 1)
fn main() {
    let _e0: vec2<f32> = test_fma();
    let _e1: i32 = 32i;
    return;
}

fn test_fma() -> vec2<f32> {
    let a: vec2<f32> = vec2(2f, 2f);
    let b: vec2<f32> = vec2(0.5f, 0.5f);
    let c: vec2<f32> = vec2(0.5f, 0.5f);
    return fma(a, b, c);
}

fn test_integer_dot_product() -> i32 {
    let a_2_: vec2<i32> = vec2(1i, 1i);
    let b_2_: vec2<i32> = vec2(1i, 1i);
    let c_2_: i32 = dot(a_2_, b_2_);
    let a_3_: vec3<u32> = vec3(1u, 1u, 1u);
    let b_3_: vec3<u32> = vec3(1u, 1u, 1u);
    let c_3_: u32 = dot(a_3_, b_3_);
    let c_4_: i32 = 32i;
    return c_4_;
}
