fn splat(m: f32, n: i32) -> vec4<f32> {
    let a_2: vec2<f32> = (((vec2(2f, 2f) + vec2(m)) - vec2(4f, 4f)) / vec2(8f, 8f));
    let b: vec4<i32> = (vec4(n) % vec4(2i, 2i, 2i, 2i));
    return (a_2.xyxy + vec4<f32>(b));
}
