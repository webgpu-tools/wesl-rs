@group(0) @binding(0)
var<uniform> r_data: Data;

@group(0) @binding(2)
var r_sampler: sampler;

@group(0) @binding(1)
var r_texture: texture_cube<f32>;

struct Data {
    proj_inv: mat4x4<f32>,
    view: mat4x4<f32>
}

struct VertexOutput {
    @builtin(position)
    position: vec4<f32>,
    @location(0)
    uv: vec3<f32>
}

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    let _e4: vec4<f32> = textureSample(r_texture, r_sampler, in.uv);
    return _e4;
}

@vertex
fn vs_main(@builtin(vertex_index) vertex_index: u32) -> VertexOutput {
    var tmp1_: i32;
    var tmp2_: i32;
    tmp1_ = (i32(vertex_index) / 2i);
    tmp2_ = (i32(vertex_index) & 1i);
    let _e9: i32 = tmp1_;
    let _e15: i32 = tmp2_;
    let pos: vec4<f32> = vec4<f32>(((f32(_e9) * 4f) - 1f), ((f32(_e15) * 4f) - 1f), 0f, 1f);
    let _e27: vec4<f32> = r_data.view[0];
    let _e32: vec4<f32> = r_data.view[1];
    let _e37: vec4<f32> = r_data.view[2];
    let inv_model_view: mat3x3<f32> = transpose(mat3x3<f32>(_e27.xyz, _e32.xyz, _e37.xyz));
    let _e43: mat4x4<f32> = r_data.proj_inv;
    let unprojected: vec4<f32> = (_e43 * pos);
    return VertexOutput(pos, (inv_model_view * unprojected.xyz));
}
